<section>
  <div class="container">
    <div class="row mt-4">
      {{#if products}}
        {{#each products}}
          <div class="col-md-3 mt-3">
            <div class="card" style="width: 15rem;">
              <img
                class="card-img-top"
                src="images/product-images/{{this._id}}.jpg"
                alt="Card image cap"
                style="height: 18rem;"
              />
              <div class="card-body text-center">
                <h5 class="card-title">{{this.name}}</h5>
                <p class="card-text">{{this.description}}</p>
                <p class="card-text">Rs.{{this.price}}</p>
                <button
                  onclick="addToCart('{{this._id}}')"
                  class="btn btn-primary"
                >Add to Cart</button>
                {{!-- <a href="/add-to-cart/{{this._id}}" class="btn btn-primary">Add
                  to Cart</a> --}}
              </div>
            </div>
          </div>
        {{/each}}
      {{/if}}
    </div>

  </div>
</section>