<section>
  <div class="container mt-5">
    <div class="row">
      {{#each products}}
        <div class="col-md-3 mb-3">
          <div class="card" style="width: 15rem;">
            <img
              class="card-img-top"
              src="/images/product-images/{{this.product._id}}.jpg"
              alt="Card image cap"
              style="height: 13rem;"
            />
            <div class="card-body">
              <h5 class="card-title">{{this.product.name}}</h5>
              <p class="card-text">Qunatity : {{this.quantity}}</p>
              <p class="card-text">Rs.{{this.product.price}}</p>

            </div>
          </div>
        </div>
      {{/each}}

    </div>
  </div>
</section>